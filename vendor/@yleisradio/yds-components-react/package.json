{
  "name": "@yleisradio/yds-components-react",
  "version": "2.8.0",
  "sideEffects": false,
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/yds-components-react/src/index.d.ts",
  "main": "./lib/cjs/index.js",
  "files": [
    "lib",
    "README.md",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yleisradio/yle-design-system.git"
  },
  "scripts": {
    "build": "rm -rf lib && yarn build:esm && yarn build:cjs",
    "build:cjs": "rm -rf lib/cjs && yarn rollup --config ./rollup.config-cjs.mjs && cp .package.cjs.json lib/cjs/package.json",
    "build:esm": "rm -rf lib/esm && yarn rollup --config ./rollup.config-esm.mjs && cp .package.esm.json lib/esm/package.json",
    "lint": "eslint .",
    "test": "jest",
    "type-check": "tsc --project tsconfig.build.json"
  },
  "peerDependencies": {
    "@yleisradio/yds-core": "2.0.8",
    "@yleisradio/yds-icons-react": "2.0.4",
    "react": ">= 17.0.0",
    "react-dom": ">= 17.0.0",
    "styled-components": "^6.1.8"
  },
  "dependencies": {
    "downshift": "^8.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.1.0",
    "@types/react": "18.2.25",
    "@types/react-dom": "^18.3.1",
    "@yleisradio/yds-core": "workspace:*",
    "@yleisradio/yds-icons-react": "workspace:*",
    "@yleisradio/yds-infographic-icons-react": "workspace:*",
    "babel-plugin-styled-components": "^2.1.4",
    "change-case": "^5.4.2",
    "csstype": "^3.1.3",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-fixed-jsdom": "^0.0.10",
    "jest-styled-components": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.0.12",
    "rollup": "^4.21.1",
    "styled-components": "^6.1.8",
    "tinycolor2": "^1.6.0",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2"
  }
}

{
  "name": "@yleisradio/yds-icons-react",
  "version": "2.0.4",
  "sideEffects": false,
  "module": "./lib/esm/index.js",
  "main": "./lib/cjs/yds-icons-react/src/index.js",
  "files": [
    "lib",
    "README.md",
    "!**/*.tsbuildinfo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yleisradio/yle-design-system.git"
  },
  "scripts": {
    "build": "rm -rf lib && yarn build:esm && yarn build:cjs",
    "build:cjs": "rm -rf lib/cjs && tsc --project tsconfig.build.cjs.json && tsc-alias --project tsconfig.build.cjs.json && cp .package.cjs.json lib/cjs/package.json",
    "build:esm": "rm -rf lib/esm && yarn rollup --config ./rollup.config-esm.mjs && cp .package.esm.json lib/esm/package.json",
    "generate-icons": "node scripts/generate-icons.mjs",
    "type-check:cjs": "tsc --project tsconfig.build.cjs.json && tsc-alias --project tsconfig.build.cjs.json",
    "type-check:esm": "tsc --project tsconfig.build.esm.json && tsc-alias --project tsconfig.build.esm.json",
    "type-check": "yarn type-check:cjs && yarn type-check:esm"
  },
  "peerDependencies": {
    "@yleisradio/yds-core": "^2.0.0",
    "react": ">= 17.0.0",
    "react-dom": ">= 17.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/eslint": "^8",
    "@types/react": "^18.3.1",
    "@yleisradio/yds-core": "workspace:*",
    "eslint": "8.57.0",
    "react": "^18.3.1",
    "rollup": "^4.21.1",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2"
  }
}
